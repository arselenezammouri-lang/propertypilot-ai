# ═══════════════════════════════════════════════════════════════
# PROPERTYPILOT AI — Master Environment Variables
# Copy to .env.local for local development
# Set ALL required vars on Vercel → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ═══ APP ═══
NEXT_PUBLIC_APP_URL=https://propertypilot-ai.vercel.app

# ═══ SUPABASE (required) ═══
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ═══ STRIPE (required) ═══
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_BOOST_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_STARTER_YEARLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_YEARLY_PRICE_ID=price_xxx

# ═══ AI — PRIMARY (required) ═══
OPENAI_API_KEY=sk-proj_YOUR_KEY
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# ═══ AI — VISUAL (required for Visual AI) ═══
REPLICATE_API_TOKEN=r8_YOUR_KEY

# ═══ EMAIL (required) ═══
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL=noreply@propertypilot.ai

# ═══ VOICE + COMMUNICATIONS ═══
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID_DEFAULT=21m00Tcm4TlvDq8ikWAM
BLAND_AI_API_KEY=org_YOUR_KEY
BLAND_AI_WEBHOOK_SECRET=your-webhook-secret
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1XXXXXXXXXX

# ═══ WHATSAPP (Meta Cloud API) ═══
WHATSAPP_BUSINESS_TOKEN=your-meta-token
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_VERIFY_TOKEN=propertypilot-wa-verify-2026

# ═══ SOCIAL MEDIA PUBLISHING ═══
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-token
TIKTOK_CLIENT_KEY=your-tiktok-key
TIKTOK_CLIENT_SECRET=your-tiktok-secret
LINKEDIN_CLIENT_ID=your-linkedin-id
LINKEDIN_CLIENT_SECRET=your-linkedin-secret

# ═══ GOOGLE CLOUD ═══
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_YOUR_KEY
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ═══ MICROSOFT (Outlook + Calendar) ═══
MICROSOFT_OAUTH_CLIENT_ID=your-ms-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=your-ms-client-secret
MICROSOFT_TENANT_ID=common

# ═══ CALENDAR ═══
CAL_COM_API_KEY=your-cal-com-key
CAL_COM_WEBHOOK_SECRET=your-cal-webhook-secret

# ═══ VIRTUAL TOURS ═══
MATTERPORT_API_KEY=your-matterport-key
MATTERPORT_API_SECRET=your-matterport-secret
CLOUDPANO_API_KEY=your-cloudpano-key
LUMA_AI_API_KEY=your-luma-ai-key
CUBICASA_API_KEY=your-cubicasa-key

# ═══ DATA + INTELLIGENCE ═══
COPERNICUS_USERNAME=your-copernicus-user
COPERNICUS_PASSWORD=your-copernicus-pass
CASAFARI_API_KEY=your-casafari-key
IDEALISTA_DATA_API_KEY=your-idealista-data-key

# ═══ DOCUMENTS + E-SIGNATURE ═══
DOCUSIGN_INTEGRATION_KEY=your-docusign-key
DOCUSIGN_USER_ID=your-docusign-user
DOCUSIGN_ACCOUNT_ID=your-docusign-account
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
SIGNWELL_API_KEY=your-signwell-key
YOUSIGN_API_KEY=your-yousign-key

# ═══ INFRASTRUCTURE ═══
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=propertypilot-ai
SENTRY_AUTH_TOKEN=your-sentry-auth
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ═══ PORTAL PUBLISHING ═══
ESTATESYNC_API_KEY=your-estatesync-key
IDEALISTA_API_KEY=your-idealista-key
IDEALISTA_API_SECRET=your-idealista-secret

# ═══ SECURITY ═══
SESSION_SECRET=generate-64-char-random-string
INTERNAL_CALLBACK_SECRET=generate-64-char-random-string
CRON_SECRET=generate-32-char-random-string

# ═══ ADMIN (disable in production) ═══
ADMIN_FORCE_LOGIN_ENABLED=false
ADMIN_FORCE_LOGIN_SECRET=change-me
ADMIN_FORCE_LOGIN_USER_ID=00000000-0000-0000-0000-000000000000

# ═══ ANALYTICS ═══
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
