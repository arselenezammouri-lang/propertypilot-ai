# PropertyPilot AI - Environment Variables
# Copy this file to .env.local and fill in your values

# --- 🌍 IDENTITY & PRODUCTION URL ---
NEXT_PUBLIC_APP_URL=https://propertypilot-ai.vercel.app
# Staging / custom preview: force robots.txt to Disallow: / (no sitemap) and X-Robots-Tag: noindex, nofollow on HTML/API via middleware. Vercel Preview sets VERCEL_ENV=preview and is blocked automatically.
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=true
# Vercel Production: set explicitly to avoid a stray "true" from copied env (preview still noindexes via VERCEL_ENV=preview).
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=false
# Opzionale: codice referral se la tabella profiles non ha ancora colonne referral (default PP)
# NEXT_PUBLIC_REFERRAL_FALLBACK_CODE=PP
SESSION_SECRET=change-me-to-a-long-random-secret
ADMIN_FORCE_LOGIN_SECRET=change-me-to-a-different-long-random-secret
ADMIN_FORCE_LOGIN_ENABLED=false
ADMIN_FORCE_LOGIN_USER_ID=00000000-0000-0000-0000-000000000000
NEXT_DISABLE_TURBO=1

# --- 🐘 DATABASE (NEON POSTGRESQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# --- 🔥 SUPABASE (AUTH & CORE DATA) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- 💳 STRIPE LIVE (IL MOTORE DEI SOLDI) ---
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# --- 🏷️ STRIPE PRICE IDS (LIVE - PREZZI DIAMANTE) ---
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_1StsWIA1is7KNmaevO6UdO0Z
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1StsZEA1is7KNmae5XkGgEr4
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_1StsbAA1is7KNmae4taYsNtk
NEXT_PUBLIC_STRIPE_AGENCY_BOOST_PRICE_ID=price_1SvkovA1is7KNmaebfhoJ3lK

# --- 🤖 AI ENGINE & COMMUNICATIONS ---
OPENAI_API_KEY=sk-proj_YOUR_KEY
BLAND_AI_API_KEY=org_YOUR_KEY
RESEND_API_KEY=re_YOUR_KEY
BLAND_AI_WEBHOOK_SECRET=change-me-webhook-secret
INTERNAL_CALLBACK_SECRET=change-me-internal-callback-secret

# --- 🛡️ EDGE / ANTI-ABUSE (middleware, per server instance) ---
# Rate limit: max requests per IP per window for /api/* (webhooks & health skipped).
# In production defaults ON; set to false to disable (e.g. load testing behind a single IP).
# EDGE_API_RATE_LIMIT_ENABLED=true
# EDGE_API_RATE_LIMIT_MAX=180
# EDGE_API_RATE_LIMIT_WINDOW_MS=60000
# Optional: Upstash Redis for cross-instance API rate limit (same max/window as above)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Stricter limit for costly AI routes (POST only; same Redis, prefix pp:mw:ai)
# EDGE_AI_RATE_LIMIT_MAX=30
# EDGE_AI_RATE_LIMIT_WINDOW_MS=60000
# Per-user (Supabase session) limit on costly AI POSTs — production on by default
# EDGE_AI_USER_RATE_LIMIT_ENABLED=true
# EDGE_AI_USER_RATE_LIMIT_MAX=20
# EDGE_AI_USER_RATE_LIMIT_WINDOW_MS=60000
# Block requests with no User-Agent (bots/scrapers). Default true in production.
# EDGE_BLOCK_EMPTY_UA=true
# Block known scanner/tool User-Agents. Default true in production.
# EDGE_BLOCK_SCANNER_UA=true

# --- 🤖 Cloudflare Turnstile (login + signup — set BOTH or neither) ---
# https://developers.cloudflare.com/turnstile/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- 🛡️ Content-Security-Policy (Report-Only — does not block; logs violations) ---
# Production: ON by default. Set to false to disable.
# CSP_REPORT_ONLY_ENABLED=true
# Local dev: off unless CSP_REPORT_ONLY_IN_DEV=true
# CSP_REPORT_ONLY_IN_DEV=true
# Optional: POST endpoint for violation reports (legacy report-uri)
# CSP_REPORT_URI=https://your-endpoint.example/csp-report

# --- 📦 API body size (preflight for POST/PUT/PATCH; max 10 MiB cap) ---
# API_MAX_BODY_BYTES=524288

# --- 🌐 API Origin / CSRF (browser POST with Origin header) ---
# Production: set true to reject POST/PUT/PATCH from apiWrapper when Origin is not app or API_ALLOWED_ORIGINS.
# API_STRICT_BROWSER_ORIGIN=true
# Comma-separated extra allowed origins (staging, preview URLs).
# API_ALLOWED_ORIGINS=https://staging.yourdomain.com
# For /api/public/lead-capture embeds: comma-separated third-party site origins (required for embed policy to enforce).
# API_EMBED_ALLOWED_ORIGINS=https://client-agency-site.com

# --- 📋 Audit sicurezza (JSON su stdout / log Vercel) ---
# In production attivo di default. Imposta un salt lungo casuale per abilitare ip_hash (primi 16 hex SHA-256).
# SECURITY_AUDIT_LOG=true
# SECURITY_AUDIT_IP_SALT=change-me-long-random-string