# PropertyPilot AI - Environment (local development)
# Copy to .env.local and fill in your values.
# See .env.example for production-style vars.

# --- Supabase (Auth & Data) ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (must match products in Stripe Dashboard)
# Plan: Starter, Pro, Agency; one-time: Agency Boost
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_AGENCY_BOOST_PRICE_ID=price_...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- App URL (used in emails, callbacks, sitemap) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: block all search indexing (robots Disallow: / + X-Robots-Tag on responses). Preview on Vercel uses VERCEL_ENV=preview without this flag.
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=true
# On Vercel Production, set NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=false explicitly if you reuse env snippets (preview still noindexes via VERCEL_ENV).
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=false

# --- Optional: Email (Resend) ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Optional: Smoke tests ---
# BASE_URL=http://localhost:3000
# TEST_EMAIL=your-test-user@example.com
# TEST_PASSWORD=your-test-password
